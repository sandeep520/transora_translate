# Active translation provider: "google" (default) or "mymemory".
# Both are free, require NO API key, and are CORS-enabled (browser-callable).
NEXT_PUBLIC_TRANSLATION_API=google

# Optional: a valid email lifts MyMemory's free anonymous limit
# from ~1,000 to ~50,000 words/day. Still no API key required.
NEXT_PUBLIC_MYMEMORY_EMAIL=
